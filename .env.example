# Copy to .env and fill in values
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/financial_copilot

# Langfuse (optional, for observability)
